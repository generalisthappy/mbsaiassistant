# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-...

# Optional. Defaults to openai/gpt-4o-mini (cheap, reliable) if unset.
# Free options exist but are frequently rate-limited; check
# https://openrouter.ai/models (filter: Free). Examples:
#   openai/gpt-4o-mini (default, paid), anthropic/claude-3.5-haiku (paid),
#   meta-llama/llama-3.3-70b-instruct:free, qwen/qwen3-coder:free
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional attribution headers sent to OpenRouter.
OPENROUTER_REFERER=https://mbsaiassistant.local
